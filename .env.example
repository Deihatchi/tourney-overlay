# Tourney-Overlay Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Challonge API Key
# Get it from: https://challonge.com/settings/developer
CHALLENGE_API_KEY=your_api_key_here

# Optional: Your Challonge username/organization subdomain
# Only needed if your account uses an organization subdomain
# Leave empty if you don't have one
CHALLENGE_USERNAME=

# Server settings (usually don't need to change)
SF_HOST=0.0.0.0
SF_PORT=8000