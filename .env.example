# Tourney-Overlay Environment Variables
# Copy this file to .env and fill in your values

# NOTE: API key is configured via the Dashboard web UI.
# No env vars are required to run the container.
# Just pull and start — configure everything at http://localhost:8002

# Optional: Pre-configure API key at container level
# (not needed — you can enter it in the dashboard)
# CHALLENGE_API_KEY=your_api_key_here
# CHALLENGE_USERNAME=

# Server settings (usually don't need to change)
SF_HOST=0.0.0.0
SF_PORT=8000